{"version":3,"kind":"Article","sha256":"6778156dd105e5b53bb773b65826e72e243bf4b04fee055d4ece295b489dde07","slug":"events.uc-open-4-2025.speakers.todd-grappone","location":"/events/uc-open-4-2025/speakers/todd-grappone.md","dependencies":[],"frontmatter":{"title":"Todd Grappone","github":"https://github.com/UC-OSPO-Network/ucospo.net","copyright":"2024","numbering":{"title":{"offset":1}},"source_url":"https://github.com/UC-OSPO-Network/ucospo.net/blob/main/events/uc-open-4-2025/speakers/todd-grappone.md","edit_url":"https://github.com/UC-OSPO-Network/ucospo.net/edit/main/events/uc-open-4-2025/speakers/todd-grappone.md","thumbnail":"/build/todd-grappone-d8da5d6efa509e2f61e026ecc9b55330.jpeg","exports":[{"format":"md","filename":"todd-grappone.md","url":"/build/todd-grappone-e06d63991ab084837c56c0ebc74bf6b1.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"image","url":"/build/todd-grappone-d8da5d6efa509e2f61e026ecc9b55330.jpeg","alt":"Speaker photo","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"D6mPPtqv1G","urlSource":"headshots/todd-grappone.jpeg"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Todd Grappone is a librarian and information technology expert with over twenty years of experience in academic institutions.\nHe is the Associate University Librarian for Digital Initiatives & Information Technology, Research and Development at UCLA.\nHe is responsible for ensuring that the library maintains a reliable, scalable, and sustainable environment.\nHe oversees five enterprise-wide departments to promote and coordinate public services and develop connections with research faculty to meet their evolving needs.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"dlrAWkZYwM"}],"key":"qG8fZFB78P"},{"type":"paragraph","position":{"start":{"line":12,"column":1},"end":{"line":13,"column":1}},"children":[{"t