{"version":3,"kind":"Article","sha256":"43a439ee80067ec1a5bac425ce1904e79f97d4a14f9f006efed079626bda2339","slug":"events.uc-open-4-2025.speakers.heather-meeker","location":"/events/uc-open-4-2025/speakers/heather-meeker.md","dependencies":[],"frontmatter":{"title":"Heather Meeker","github":"https://github.com/UC-OSPO-Network/ucospo.net","copyright":"2024","numbering":{"title":{"offset":1}},"source_url":"https://github.com/UC-OSPO-Network/ucospo.net/blob/main/events/uc-open-4-2025/speakers/heather-meeker.md","edit_url":"https://github.com/UC-OSPO-Network/ucospo.net/edit/main/events/uc-open-4-2025/speakers/heather-meeker.md","thumbnail":"/build/heather-meeker-49f6939d6298fa688904a919a6490a71.jpg","exports":[{"format":"md","filename":"heather-meeker.md","url":"/build/heather-meeker-c5b3bb847205d5c79a96a40b47a0aec4.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"image","url":"/build/heather-meeker-49f6939d6298fa688904a919a6490a71.jpg","alt":"Speaker photo","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"tht1CxY9J5","urlSource":"headshots/heather-meeker.jpg"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Heather Meeker is a partner at ","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"cIgQP7ZvUr"},{"type":"link","url":"https://www.techlawpartners.com","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Tech Law Partners, LLP","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"o6EFhRUA8P"}],"urlSource":"https://www.techlawpartners.com","key":"ODNtjJhbTa"},{"type":"text","value":", a law firm focused on technology transactions. She is also co-founder of Chinstrap Community, a resource center for investors and founders starting commercial open source businesses.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"qQIlbTAy5T"}],"key":"afBN5OBDve"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Meeker advises clients on intellectual property and licensing matters. She is an internationally-known specialist in open source software licensing. She is the primary drafter of many widely-used licenses, including Elastic 2.0, and served on the core drafting team for Mozilla Public License 2.0 and the PolyForm licenses. Her book Open Source for Business, now in its fourth edition, is a definitive handbook for lawyers, engineers, and businesspersons on open source licensing in business. Her Technology Licensing: A Primer, is a widely used handbook for technology licensing specialists. Her new book, From Project to Profit, is a handbook for structuring commercial open source software businesses.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"tmWIOk09eH"}],"key":"KI6v2rOGta"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"In 2019, Meeker was named by Business Insider as one of the ten people transforming the way the technology industry does business, along with the CEOs of Salesforce, Stripe, and Microsoft. She was the only lawyer on this list.","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"ulKAgXhb0b"}],"key":"oDYfs9cWu6"},{"type":"paragraph","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"She is a member of the Advisory Council for the American Law Institute’s projects on Principles of the Law of Software Contracts (2010) and Restatement of Law, Copyright (ongoing). She is also a board member of the IEEE-ISTO and the StarkNet Foundation.","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"dBxEy617k5"}],"key":"p9iO7mJEhH"},{"type":"paragraph","position":{"star