mg","key":"sisEZRYXG0","urlSource":"./speaker-headshots/emily-lovell.jpg"},{"type":"heading","depth":3,"position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"Emily Lovell | UCSC","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"TSnas6wK0a"}],"identifier":"emily-lovell-ucsc","label":"Emily Lovell | UCSC","html_id":"emily-lovell-ucsc","implicit":true,"key":"kgvtlw5Qv3"},{"type":"paragraph","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"Dr. Emily Lovell is the Associate Director of the UC Santa Cruz Open Source Program Office and holds a faculty appointment in the Computer Science and Engineering department. Her research and teaching use novel domains to invite broader participation in computing, with her postdoctoral work focusing on newcomers to open source. Emily previously served on faculty at Berea College, where she developed and taught courses on open source contribution and computational craft. She designed the LilyTiny, an open-source sewable microcontroller that has been commercially available as part of the LilyPad Arduino product line for over a decade. She holds a S.M. in Media Arts & Sciences from the MIT Media Lab and a Ph.D. in Computer Science from UC Santa Cruz.","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"B9JEZIYaYM"}],"key":"SBnyjBBTsn"}],"class":"speaker-bio","key":"qldq6UaBPi"}],"key":"K7AQFiTHGx"}],"key":"D69vLKRKFh"},"references":{"cite":{"order":[],"data":{}}},"footer":{},"domain":"http://localhost:3000"}