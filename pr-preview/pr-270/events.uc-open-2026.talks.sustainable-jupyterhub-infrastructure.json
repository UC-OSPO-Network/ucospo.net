{"version":3,"kind":"Article","sha256":"71e7deafcc4c633d7b6f08406c2507e90e0055136842eb217b1e3b035a923e67","slug":"events.uc-open-2026.talks.sustainable-jupyterhub-infrastructure","location":"/events/uc-open-2026/talks/sustainable-jupyterhub-infrastructure.md","dependencies":[],"frontmatter":{"title":"From Deployment to Ecosystem: Building Sustainable JupyterHub Infrastructure for Research and Teaching","github":"https://github.com/UC-OSPO-Network/ucospo.net","copyright":"2024","numbering":{"title":{"offset":1}},"source_url":"https://github.com/UC-OSPO-Network/ucospo.net/blob/main/events/uc-open-2026/talks/sustainable-jupyterhub-infrastructure.md","edit_url":"https://github.com/UC-OSPO-Network/ucospo.net/edit/main/events/uc-open-2026/talks/sustainable-jupyterhub-infrastructure.md","thumbnail":"/build/eric-van-dusen-ef6f48bfc5c1f14305e9f644e73c0aee.png","exports":[{"format":"md","filename":"sustainable-jupyterhub-infrastructure.md","url":"/build/sustainable-jupyterh-662dc65968939f9d49495d34c32fec8d.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Abstract","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"YK4n1E9c07"}],"identifier":"abstract","label":"Abstract","html_id":"abstract","implicit":true,"key":"W8X4jN1UNJ"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"advancing research and teaching across institutions. We will highlight a commitment to a fully open-source stack, reproducible DevOps practices, and transparent engineering through public repositories. The discussion will emphasize technical DevOps workflows including continuous integration and deployment (CI/CD), infrastructure-as-code, automated testing, containerization, and cost-monitoring dashboards that support sustainable cloud operations. We will also discuss how contributing upstream to core open-source projects strengthens reliability, reduces technical debt, and accelerates innovation across the ecosystem. Drawing on multi-campus implementations such as CAL-ICOR and CloudBank Classroom, developed in close collaboration with 2i2c, we will illustrate how shared infrastructure models enable cross-campus provisioning, environment harmonization, and scalable support for students and researchers. The panel will demonstrate how disciplined open engineering practices can build resilient, extensible computational ecosystems that serve multiple institutions.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"Fb4gfFOPx8"}],"key":"MusTLDjgUC"},{"type":"heading","depth":2,"position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"About the Speakers","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"UZt7TC7pmK"}],"identifier":"about-the-speakers","label":"About the Speakers","html_id":"about-the-speakers","implicit":true,"key":"SFMdK2sYyg"},{"type":"div","children":[{"type":"image","url":"/build/eric-van-dusen-ef6f48bfc5c1f14305e9f644e73c0aee.png","alt":"Eric Van Dusen","align":"center","class":"speaker-bio-img","key":"Gsxo8jAhrl","urlSource":"./speaker-headshots/eric-van-dusen.png"},{"type":"heading","depth":3,"position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"Eric Van Dusen","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"rdTbdevfIQ"}],"identifier":"eric-van-dusen","label":"Eric Van Dusen","html_id":"eric-van-dusen","implicit":true,"key":"tcC2K0wdLC"},{"type":"paragraph","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"Eric Van Dusen is a lecturer and Technology and Outreach Lead in Data Science Undergraduate Studies within the College of Computing, Data Science, and Society at UC Berkeley. He has spent the past eight years helping to build the Data Science undergraduate major, designing and teaching new courses, training faculty to incorporate interactive computing into their teaching, and serving on the steering committee for the campus-wide JupyterHub infrastructure. He co-leads the National Workshop on Data Science Education and the California Alliance for Data Science Education, and leads initiatives to support Community Colleges in teaching Data Science through professional development, JupyterHub support, and collaborative curriculum development.","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"GAJNGyGYVK"}],"key":"Qgfgqg6BEI"}],"class":"speaker-bio","key":"zUwc25HvTb"},{"type":"div","children":[{"type":"image","url":"/build/ryan-lovett-5bb7b983cc733543a49de90142cf4b5b.jpg","alt":"Ryan Lovett","align":"center","class":"speaker-bio-img","key":"XeBEPIVQfL","urlSource":"./speaker-headshots/ryan-lovett.jpg"},{"type":"heading","depth":3,"position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"Ryan Lovett","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"Og79l2nWEf"}],"identifier":"ryan-lovett","label":"Ryan Lovett","html_id":"ryan-lovett","implicit":true,"key":"OjK5C6NGeh"},{"type":"paragraph","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"text","value":"Ryan Lovett is the Director of Computing at the Statistical Computing Facility at UC Berkeley. He played an integral role in the success of the Foundations of Data Science course, creating a new hosted computing environment and leading development of the platform to support hundreds of students. Lovett has been named a Jupyter Distinguished Contributor for his substantial contributions to the Jupyter open-source project.","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"lrrP4V9ALW"}