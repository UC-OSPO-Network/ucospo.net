{"version":3,"kind":"Article","sha256":"7f6e6e6002c6b5b0e2f64e1a74540db3333acd09a34ea491ad478045f31c3d88","slug":"events.uc-open-2026.talks.jupyter-book-next-gen-tools","location":"/events/uc-open-2026/talks/jupyter-book-next-gen-tools.md","dependencies":[],"frontmatter":{"title":"Jupyter Book: Next-generation Tools for Creating Computational Narratives","github":"https://github.com/UC-OSPO-Network/ucospo.net","copyright":"2024","numbering":{"title":{"offset":1}},"source_url":"https://github.com/UC-OSPO-Network/ucospo.net/blob/main/events/uc-open-2026/talks/jupyter-book-next-gen-tools.md","edit_url":"https://github.com/UC-OSPO-Network/ucospo.net/edit/main/events/uc-open-2026/talks/jupyter-book-next-gen-tools.md","thumbnail":"/build/chris-holdgraf-0afaa3dd4fa508d56d5f88ccacebc2e0.png","exports":[{"format":"md","filename":"jupyter-book-next-gen-tools.md","url":"/build/jupyter-book-next-ge-adfb8ca559ef5263241ac5fce789bfb9.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Abstract","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"YpVPimzNmi"}],"identifier":"abstract","label":"Abstract","html_id":"abstract","implicit":true,"key":"NpG2CVjhzS"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Jupyter Book is a core tool for sharing computational science, powering more than 14,000 open, online textbooks, knowledge bases, lectures, courses and community sites. It allows researchers and educators to create books and knowledge bases that are reusable, reproducible, and interactive.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"LsHivN2wcP"}],"key":"ypfb4zMVuh"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Over the past two years, we have rebuilt Jupyter Book from the ground up, focused on allowing authors to produce machine readable, semantically structured content that can be flexibly deployed, reused, and cross referenced in unprecedented ways. We achieved this by adopting, stewarding, and developing the ","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"aN07Zt2XWH"},{"type":"link","url":"https://mystmd.org","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"MyST Markdown Document Engine","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"Z67ffxTtHo"}],"urlSource":"https://mystmd.org","key":"KDIyCVWELp"},{"type":"text","value":", a more flexible and extensible engine that integrates with Jupyter for interactive computation.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"pTUQxx8Kz4"}],"key":"ppKnMy1kzt"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"In this talk, I’ll cover the key differentiating ideas driving Jupyter Book and MyST, and showcase real-world examples like The Turing Way, QuantEcon, Project Pythia, and the SciPy Proceedings.","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"Xxzf4eCaOS"}],"key":"gyDWSW8R0T"},{"type":"thematicBreak","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"EllrzpoHDZ"},{"type":"div","children":[{"type":"image","url":"/build/chris-holdgraf-0afaa3dd4fa508d56d5f88ccacebc2e0.png","alt":"Chris Holdgraf","align":"center","class":"speaker-bio-img","key":"KigtieVE2P","urlSource":"./speaker-headshots/chris-holdgraf.png"},{"type":"heading","depth":3,"position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"Chris Holdgraf | 2i2c (","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"pbfdTcE2C5"},{"type":"link","url":"http://2i2c.org","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"2i2c.org","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"rpA3kg4g5u"}],"urlSource":"http://2i2c.org","key":"fRJMk38XHm"},{"type":"text","value":")","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"lwL32dEa2s"}],"identifier":"chris-holdgraf-2i2c-2i2c-org","label":"Chris Holdgraf | 2i2c (2i2c.org)","html_id":"chris-holdgraf-2i2c-2i2c-org","implicit":true,"key":"RbjVlD52sX"},{"type":"paragraph","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"text","value":"Chris is the Executive Director of 2i2c. He is on the Jupyter Executive Council as well as the Jupyter Foundation Board. He has been a co-lead of several projects within the Jupyter ecosystem for over ten years (particularly the JupyterHub and Binder projects, as well as the Jupyter Book project). He’s interested in the boundary between technology, open-source software, and research and education workflows, as well as how open communities can support and extend these workflows to make science more impactful and inclusive.","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"p7593hZTw2"}],"key":"rYABxZeqrj"}],"class":"speaker-bio","key":"b2LSvRKAX8"}],"key":"G8kbHmlqXs"}],"key":"xXTq7ttK8O"},"references":{"cite":{"order":[],"data":{}}},"footer":{},"domain":"http://localhost:3000"}