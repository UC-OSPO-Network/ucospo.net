{"version":3,"kind":"Article","sha256":"681d33adb53c738881e991ff03844268b36b4a08a68ef4c87c25e21a59d715a9","slug":"events.uc-open-4-2025.speakers.tony-wasserman","location":"/events/uc-open-4-2025/speakers/tony-wasserman.md","dependencies":[],"frontmatter":{"title":"Tony Wasserman","github":"https://github.com/UC-OSPO-Network/ucospo.net","copyright":"2024","numbering":{"title":{"offset":1}},"source_url":"https://github.com/UC-OSPO-Network/ucospo.net/blob/main/events/uc-open-4-2025/speakers/tony-wasserman.md","edit_url":"https://github.com/UC-OSPO-Network/ucospo.net/edit/main/events/uc-open-4-2025/speakers/tony-wasserman.md","thumbnail":"/build/tony-wasserman-594234cc164a62f572c50fe997281f3f.jpg","exports":[{"format":"md","filename":"tony-wasserman.md","url":"/build/tony-wasserman-2b55ad1f29f7aa6eb764283ab34785e7.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"image","url":"/build/tony-wasserman-594234cc164a62f572c50fe997281f3f.jpg","alt":"Speaker photo","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"RPPry4AAuC","urlSource":"headshots/tony-wasserman.jpg"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Tony Wasserman has divided his career between academia and industry. He is currently Principal of Software Methods and Tools, consulting for tech founders and software startups, and an Advisor in the Berkeley SkyDeck accelerator. He was previously a Professor in the Software Management program at Carnegie Mellon University - Silicon Valley. Earlier, Tony was founder and CEO of Interactive Development Environments (IDE), one of the first 100 dot-coms. Tony then led an early mobile app development team at Bluestone Software (acquired by H-P), and executive positions at several startups.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"ITpXsUzIXn"}],"key":"E1NBxJYYCw"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"He is a Fellow of the IEEE, the ACM, and IFIP, honored for his contributions to integrated software engineering environments.\nHe served two terms as a Director of the Open Source Initiative (2010-2016). He was a co-founder and Chair of ACM’s SIG on Software Engineering (SIGSOFT). Tony has a Ph.D. in computer sciences from University of Wisconsin - Madison and a B.A. in mathematics and physics from UC Berkeley.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"fCfylx6ei3"}],"key":"JJ7nrIGLEQ"},{"type":"heading","depth":2,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"Session","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"rRJga1nrIy"}],"identifier":"session","label":"Session","html_id":"session","implicit":true,"key":"PZrFUCn5BN"},{"type":"paragraph","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"link","url":"/events/uc-open-4-2025/sessions/from-idea-to-impact","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"From Idea to Impact — Charting Creation and Adoption of Open Source Coming from Academia","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"Dbmz1vA7dO"}],"urlSource":"../sessions/from-idea-to-impact.md","dataUrl":"/events.uc-open-4-2025.sessions.from-idea-to-impact.json","internal":true,"protocol":"file","key":"seb6r6Ytvf"}],"key":"Mr3GL3C7xu"}],"key":"km3YjVCpY5"}],"key":"KEV3bCNPK8"},"references":{"cite":{"order":[],"data":{}}},"footer":{},"domain":"http://localhost:3000"}